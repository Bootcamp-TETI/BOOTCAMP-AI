# ============================================================
# .env.example
# Salin file ini menjadi ".env" lalu isi nilainya masing-masing.
# JANGAN commit file ".env" yang sudah berisi API key asli ke GitHub
# (sudah otomatis di-ignore lewat .gitignore).
# ============================================================

# --- Wajib diisi ---
# API key Gemini, ambil gratis di https://aistudio.google.com/apikey
GOOGLE_API_KEY=

# --- Opsional (backend main.py) — default sudah sesuai struktur folder project ---
# Folder tempat checkpoint model SegFormer disimpan
MODEL_DIR=models
# Nama file checkpoint model
CHECKPOINT_NAME=segformer_best.pt
# Folder tempat FAISS index & chunk SOP disimpan
RAG_DIR=rag
# Asumsi ground sample distance (meter/piksel) untuk estimasi luas area kerusakan
GSD_METERS_PER_PIXEL=0.3
# Level logging: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO

# --- Opsional (services/gemini_service.py) — override kalau model default gagal ---
# Cek model yang aktif untuk API key-mu lewat GeminiService().list_available_models()
GEMINI_EMBED_MODEL=gemini-embedding-001
GEMINI_GENERATION_MODEL=gemini-3.5-flash

# --- Opsional (frontend streamlit_app.py) ---
# Alamat backend FastAPI. Untuk pengembangan lokal biarkan default.
# Saat deployment (Render/Railway/Docker/dsb), ganti ke URL backend yang sesungguhnya,
# atau isi lewat .streamlit/secrets.toml dengan key yang sama: API_URL = "https://..."
API_URL=http://localhost:8000
